APP_IMAGE=go-safe-agent-gateway-app:latest
PUBLIC_DOMAIN=localhost
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

GATEWAY_API_KEY=replace-with-a-long-random-key
MAX_BODY_BYTES=1048576
CORS_ALLOW_ORIGINS=https://your-frontend.example.com

MYSQL_ROOT_PASSWORD=replace-root-password
MYSQL_DATABASE=go_agent
MYSQL_USER=go_agent
MYSQL_PASSWORD=replace-db-password

REDIS_PASSWORD=replace-redis-password
REDIS_DB=0
RATE_LIMIT_FAIL_CLOSED=true
RATE_LIMIT_PER_MINUTE=60

QDRANT_COLLECTION=agent_documents
EMBEDDING_DIMENSION=64
RAG_SCORE_THRESHOLD=0.10

ENABLE_MOCK_LLM=false
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=replace-with-provider-key
LLM_MODEL=deepseek-chat

ENABLE_MOCK_EMBEDDING=true
EMBEDDING_MODEL=text-embedding-3-small

TOOL_DEFAULT_TIMEOUT_MS=5000
MAX_SQL_ROWS=100
URL_ALLOWLIST=example.com,httpbin.org,api.github.com
ASYNC_WORKERS=2
ASYNC_QUEUE_SIZE=32
