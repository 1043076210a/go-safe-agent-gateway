{$PUBLIC_DOMAIN:localhost} {
	encode gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
	}

	@metricsWithoutAuth {
		path /metrics
		not header Authorization "Bearer {$GATEWAY_API_KEY}"
	}
	respond @metricsWithoutAuth "metrics requires bearer token" 401

	reverse_proxy app:8080
}
