APP_ENV=local
HTTP_ADDR=:8080
HTTP_PORT=8080
GATEWAY_API_KEY=
MAX_BODY_BYTES=1048576
CORS_ALLOW_ORIGINS=

MYSQL_ROOT_PASSWORD=go_agent_root
MYSQL_DATABASE=go_agent
MYSQL_USER=go_agent
MYSQL_PASSWORD=go_agent_pass
MYSQL_PORT=13306
MYSQL_DSN=go_agent:go_agent_pass@tcp(127.0.0.1:13306)/go_agent?parseTime=true

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=go_agent_redis
REDIS_DB=0
REDIS_PORT=6379
RATE_LIMIT_FAIL_CLOSED=false
RATE_LIMIT_PER_MINUTE=60

QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=agent_documents
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
EMBEDDING_DIMENSION=64
RAG_SCORE_THRESHOLD=0.10

ENABLE_MOCK_LLM=true
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
EMBEDDING_MODEL=text-embedding-3-small
ENABLE_MOCK_EMBEDDING=true

TOOL_DEFAULT_TIMEOUT_MS=5000
MAX_SQL_ROWS=100
URL_ALLOWLIST=example.com,httpbin.org,api.github.com
ASYNC_WORKERS=2
ASYNC_QUEUE_SIZE=32
PROMETHEUS_PORT=9090
PUBLIC_HTTP_PORT=8081
